# Variables d'environnement pour Vercel
JWT_SECRET=votre_jwt_secret_tres_securise_ici
NODE_ENV=production

# Pour le développement local
# JWT_SECRET=dev_secret_key_changez_en_production
# NODE_ENV=development

# Note: Le mot de passe admin est hashé avec bcrypt
# Le JWT_SECRET protège uniquement les tokens d'authentification
# Pour changer le mot de passe admin, utilisez: node setup-admin.js
